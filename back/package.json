{
  "name": "back",
  "version": "0.1.0",
  "private": true,
  "description": "Back de l'application de suivi de produits structurés",
  "scripts": {
    "dev":       "node --env-file=.env node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "start":     "node --env-file=.env node_modules/tsx/dist/cli.mjs src/server.ts",
    "snapshot":  "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs src/snapshot.ts",
    "history":   "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs src/history-snapshot.ts",
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "test":      "node --import tsx --test src/calc.test.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.7.11",
    "yahoo-finance2": "^3.15.3"
  }
}
